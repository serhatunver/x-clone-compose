{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true 
  }
}
